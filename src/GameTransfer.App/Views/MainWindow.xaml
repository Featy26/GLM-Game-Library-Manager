<ui:FluentWindow x:Class="GameTransfer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:GameTransfer.App.ViewModels"
        xmlns:conv="clr-namespace:GameTransfer.App.Converters"
        Title="GLM - Game Library Manager" Height="750" Width="1100"
        Icon="pack://application:,,,/glm.ico"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        x:Name="MainWin">

    <ui:FluentWindow.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:StringToBrushConverter x:Key="StringToBrush"/>
        <Style x:Key="CheckBoxColumnStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0,8,0"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="GLM - Game Library Manager" ShowMaximize="True" ShowMinimize="True"/>

        <TabControl Grid.Row="1" Margin="10">

            <!-- ==================== Bibliothek Tab ==================== -->
            <TabItem Header="Bibliothek">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Library.LauncherFilters}"
                                  SelectedItem="{Binding Library.SelectedLauncherFilter}"/>
                        <TextBlock Grid.Column="2" Text="Suche:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <TextBox Grid.Column="3" Text="{Binding Library.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <ui:Button Grid.Column="5" Content="Alle auswählen" Command="{Binding Library.SelectAllCommand}" Margin="4,0"/>
                        <ui:Button Grid.Column="6" Content="Auswahl aufheben" Command="{Binding Library.DeselectAllCommand}"/>
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Library.Games}" AutoGenerateColumns="False"
                              IsReadOnly="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" Margin="0,0,0,10"
                              RowHeight="34" ColumnHeaderHeight="28">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="SizeToHeader" MinWidth="46"
                                                     CellStyle="{StaticResource CheckBoxColumnStyle}">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding DataContext.Library.IsAllSelected, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Spiel" Width="*" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding IconSource}" Width="24" Height="24"
                                                   Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding SizeText}" Header="Größe" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Binding="{Binding LauncherName}" Header="Launcher" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Binding="{Binding InstallPath}" Header="Pfad" Width="250" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GroupBox Grid.Row="2" Header="Ziel-Laufwerk" Margin="0,0,0,10">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Text="Laufwerk:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding DriveManager.Drives}"
                                      SelectedItem="{Binding DriveManager.SelectedDrive}" DisplayMemberPath="DisplayName"/>
                            <ui:Button Grid.Column="2" Content="Aktualisieren"
                                       Command="{Binding DriveManager.RefreshDrivesAsyncCommand}" Margin="8,0,0,0"/>
                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="3"
                                         Value="{Binding DriveManager.SelectedDrive.UsedPercentage, Mode=OneWay, FallbackValue=0}"
                                         Maximum="100" Height="20" Margin="0,8,0,0"/>
                        </Grid>
                    </GroupBox>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="Symlink-Fallback erstellen"
                                  IsChecked="{Binding CreateSymlinks}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Library.StatusText}"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <ui:Button Grid.Column="2" Content="Spiele scannen"
                                   Command="{Binding Library.LoadGamesCommand}" Margin="0,0,8,0" Appearance="Secondary"/>
                        <ui:Button Grid.Column="3" Content="Deinstallieren"
                                   Command="{Binding UninstallSelectedGamesCommand}" Margin="0,0,8,0" Appearance="Danger"/>
                        <ui:Button Grid.Column="4" Content="Ausgewählte verschieben"
                                   Command="{Binding MoveSelectedGamesCommand}" Appearance="Primary"/>
                    </Grid>

                    <Grid Grid.Row="1" Visibility="{Binding Library.IsLoading, Converter={StaticResource BoolToVis}}">
                        <Border Background="#80000000">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:ProgressRing IsIndeterminate="True" Width="50" Height="50"/>
                                <TextBlock Text="{Binding Library.StatusText}" Margin="0,10,0,0"
                                           HorizontalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ==================== Transfers Tab ==================== -->
            <TabItem Header="Transfers">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="{Binding Transfer.OverallStatus}" FontSize="16" FontWeight="SemiBold"/>
                        <ProgressBar Value="{Binding Transfer.OverallProgress, Mode=OneWay}" Maximum="100" Height="25" Margin="0,5,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Transfer.Transfers}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              RowHeight="70" ColumnHeaderHeight="28">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Spiel" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="4,0">
                                            <TextBlock Text="{Binding GameName}" FontWeight="Bold" FontSize="13"/>
                                            <TextBlock Text="{Binding LauncherName}" Opacity="0.6" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Pfad" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center" Opacity="0.7" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" Margin="4,0">
                                            <Run Text="{Binding SourcePath, Mode=OneTime}"/>
                                            <Run Text=" → "/>
                                            <Run Text="{Binding DestinationPath, Mode=OneTime}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Fortschritt" Width="350">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="4,0">
                                            <ProgressBar Value="{Binding Progress, Mode=OneWay}" Maximum="100" Height="16"
                                                         Visibility="{Binding HasFailed, Converter={StaticResource InvBoolToVis}}"/>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" Margin="0,2,0,0"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasFailed}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF4444"/>
                                                                <Setter Property="Opacity" Value="1"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <ui:Button Content="{Binding Transfer.PauseButtonText}" Command="{Binding Transfer.PauseResumeCommand}" Margin="0,0,8,0"
                                   IsEnabled="{Binding Transfer.IsTransferring}"/>
                        <ui:Button Content="Abbrechen" Command="{Binding Transfer.CancelTransfersCommand}"
                                   Appearance="Danger"
                                   IsEnabled="{Binding Transfer.IsTransferring}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ==================== Laufwerke Tab ==================== -->
            <TabItem Header="Laufwerke">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ui:Button Grid.Row="0" Content="Laufwerke aktualisieren"
                               Command="{Binding DriveManager.RefreshDrivesAsyncCommand}" Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DriveManager.Drives}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="15" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#444" CornerRadius="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Opacity="0.7"
                                                           VerticalAlignment="Center" FontSize="13"/>
                                            </Grid>

                                            <!-- Color-coded stacked bar -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding LauncherUsage}" Margin="0,0,0,6">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Height="28" CornerRadius="2" Margin="0,0,1,0"
                                                                Background="{Binding Color, Converter={StaticResource StringToBrush}}"
                                                                ToolTip="{Binding LauncherName}">
                                                            <Border.Width>
                                                                <MultiBinding>
                                                                    <MultiBinding.Converter>
                                                                        <conv:PercentageToWidthConverter/>
                                                                    </MultiBinding.Converter>
                                                                    <Binding Path="Percentage"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Legend -->
                                            <ItemsControl Grid.Row="2" ItemsSource="{Binding LauncherUsage}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                                                            <Border Width="12" Height="12" CornerRadius="2" Margin="0,0,5,0"
                                                                    Background="{Binding Color, Converter={StaticResource StringToBrush}}"/>
                                                            <TextBlock FontSize="12" Opacity="0.8">
                                                                <Run Text="{Binding LauncherName, Mode=OneWay}"/>
                                                                <Run Text=" ("/>
                                                                <Run Text="{Binding SizeText, Mode=OneWay}"/>
                                                                <Run Text=")"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ==================== Library Import Tab ==================== -->
            <TabItem Header="Library Import">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Wähle Launcher aus, deren Spiele ins Library-System importiert werden sollen. Die Spiele werden auf der gleichen Festplatte kopiert und danach die alte Version gelöscht."
                                   TextWrapping="Wrap" Opacity="0.7" FontSize="13"/>
                        <ui:Button Grid.Column="1" Content="Neu scannen"
                                   Command="{Binding LibraryImport.ScanGamesCommand}" Margin="10,0,0,0" Appearance="Secondary"
                                   VerticalAlignment="Top"/>
                    </Grid>

                    <TextBlock Grid.Row="1" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                               Text="Verfügbare Launcher"/>

                    <!-- Launcher selection cards -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding LibraryImport.LauncherGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12" Margin="0,0,0,8" BorderThickness="1" BorderBrush="#444" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,8,0"
                                                                Background="{Binding Color, Converter={StaticResource StringToBrush}}"
                                                                VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding LauncherName}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Opacity="0.6" FontSize="12" Margin="22,2,0,0">
                                                        <Run Text="{Binding GameCount, Mode=OneWay}"/>
                                                        <Run Text=" Spiele zu importieren"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                                           Margin="0,0,20,0" Text="{Binding SizeText}"/>

                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <TextBlock Text="Geschätzte Dauer" FontSize="11" Opacity="0.5"/>
                                                    <TextBlock Text="{Binding EstimatedTime}" FontSize="14" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Already managed section -->
                            <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,10,0,8">
                                <Run Text="Bereits im Library-System ("/>
                                <Run Text="{Binding LibraryImport.ManagedGames.Count, Mode=OneWay}"/>
                                <Run Text=" Spiele)"/>
                            </TextBlock>

                            <DataGrid ItemsSource="{Binding LibraryImport.ManagedGames}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" MaxHeight="250" RowHeight="34" ColumnHeaderHeight="28">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Spiel" Width="*" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Image Source="{Binding IconSource}" Width="24" Height="24"
                                                           Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Binding="{Binding SizeText}" Header="Größe" Width="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Binding="{Binding LauncherName}" Header="Launcher" Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Binding="{Binding InstallPath}" Header="Pfad" Width="250" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding LibraryImport.StatusText}"
                                   VerticalAlignment="Center" Opacity="0.7"/>
                        <ui:Button Grid.Column="1" Content="Leere Steam Libraries löschen"
                                   Command="{Binding CleanEmptySteamLibrariesCommand}" Margin="0,0,8,0" Appearance="Danger"/>
                        <ui:Button Grid.Column="2" Content="Ausgewählte Launcher importieren"
                                   Command="{Binding ImportSelectedLaunchersCommand}" Appearance="Primary"/>
                    </Grid>

                    <Grid Grid.Row="2" Visibility="{Binding LibraryImport.IsLoading, Converter={StaticResource BoolToVis}}">
                        <Border Background="#80000000">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:ProgressRing IsIndeterminate="True" Width="50" Height="50"/>
                                <TextBlock Text="{Binding LibraryImport.StatusText}" Margin="0,10,0,0"
                                           HorizontalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
